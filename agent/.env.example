# Napster Omniagent public API key (sent as X-Api-Key)
NAPSTER_API_KEY=

# Policy Function endpoint (base URL, without the ?code= query parameter)
POLICY_FUNCTION_ENDPOINT=https://<your-function-app>.azurewebsites.net/api/policy-check

# Policy Function authorization key (embedded as ?code= on the tool URL)
POLICY_FUNCTION_KEY=

# Optional: override the Napster API base URL
# NAPSTER_BASE_URL=https://companion-api.napster.com

# Optional: override the knowledge content directory (defaults to ../knowledge)
# KNOWLEDGE_DIR=
