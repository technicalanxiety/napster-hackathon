{
  "name": "governance-advisor-frontend",
  "version": "1.0.0",
  "description": "React (Vite) single-page frontend embedding the Napster Web SDK for the Azure Governance Baseline Advisor",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "fast-check": "^4.8.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.9.0",
    "vite": "^6.0.7",
    "vitest": "^4.1.8"
  }
}
